{
  "rewrites": [
    {
      "source": "/is-:domain-safe",
      "destination": "https://detective-app-production-7080.up.railway.app/is-:domain-safe"
    },
    {
      "source": "/sitemap-domains.xml",
      "destination": "https://detective-app-production-7080.up.railway.app/sitemap-domains.xml"
    },
    {
      "source": "/scam-alerts-page",
      "destination": "https://detective-app-production-7080.up.railway.app/scam-alerts-page"
    }
  ],
  "headers": [
    {
      "source": "/og-image-v2.png",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/png"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "ETag",
          "value": ""
        }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/png"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/(.*\\.png)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    },
    {
      "source": "/(.*\\.jpg)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/jpeg"
        }
      ]
    }
  ]
}